<button @onclick="OpenModal" class="user-invite">
    <img src="icons/person-Icon.svg" />
    Invite People
</button>

@code {
    [Parameter]
    public string ConversationId { get; set; }

    void OpenModal()
    {
        var parameters = new ModalParameters();
        parameters.Add(nameof(ConversationId), ConversationId);
        Modal.Show<InviteModal>("InviteModal", parameters);
    }
}